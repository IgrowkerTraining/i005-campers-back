generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String    @id @default(uuid())
  email    String    @unique
  name     String?
  owner    Boolean   @default(false)
  password String
  Camping  Camping[]
}

model Camping {
  id                Int                @id @default(autoincrement())
  name              String
  description       String
  locationId        Int
  userId            String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  nearNature        String[]
  location          Location           @relation(fields: [locationId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  nearbyAttractions NearbyAttraction[]
  pricing           Pricing[]
  amenities         Amenity[]          @relation("AmenityToCamping")

  @@index([name])
  @@index([nearNature])
}

model Location {
  id          Int       @id @default(autoincrement())
  city        String
  region      String
  country     String    @default("España")
  coordinates String?
  campings    Camping[]
}

model Pricing {
  id            Int     @id @default(autoincrement())
  pricePerNight Float
  season        String
  campingId     Int
  camping       Camping @relation(fields: [campingId], references: [id])
}

model Amenity {
  id        Int       @id @default(autoincrement())
  name      String
  available Boolean   @default(true)
  campings  Camping[] @relation("AmenityToCamping")
}

model NearbyAttraction {
  id        Int     @id @default(autoincrement())
  name      String
  type      String
  distance  Float
  campingId Int
  camping   Camping @relation(fields: [campingId], references: [id])
}
