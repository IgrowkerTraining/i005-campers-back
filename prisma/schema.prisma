generator client {
  provider = "prisma-client-js"
}

  datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
  }

  model User {
    id    String     @id @default(uuid())
    name  String?
    email String     @unique
    password String
    owner Boolean @default(false)
    Camping Camping[]
  }

model Camping {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  location    Location  @relation(fields: [locationId], references: [id])
  locationId  Int
  nearNature      String[] // Ej: ["river", "beach"]
  pricing     Pricing[]
  amenities   Amenity[]
  nearbyAttractions NearbyAttraction[]

  user        User      @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([name]) // Optimización para búsquedas
  @@index([nearNature]) // Para búsquedas más eficientes
}

model Location {
  id          Int      @id @default(autoincrement())
  city        String
  region      String
  country     String   @default("España")
  coordinates String?
  campings    Camping[]
}

model Pricing {
  id          Int     @id @default(autoincrement())
  pricePerNight Float
  season      String
  camping     Camping @relation(fields: [campingId], references: [id])
  campingId   Int
}

model Amenity {
  id        Int      @id @default(autoincrement())
  name      String
  available Boolean  @default(true)
  campings  Camping[]
}

model NearbyAttraction {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // "playa", "montaña", "parque-nacional", etc.
  distance  Float    // En kilómetros
  camping   Camping  @relation(fields: [campingId], references: [id])
  campingId Int
}